{
  "$schema": "https://hifi.com/docs.json",
  "theme": "almond",
  "name": "HIFI Docs",
  "description": "Developer Documentation for HIFI",
  "colors": {
    "primary": "#222222",
    "light": "#F2FF66",
    "dark": "#222222"
  },
  "css": "/styles.css",
  "favicon": "/favicon.svg",
  "seo": {
    "metatags": {
      "title": "HIFI Docs",
      "description": "Build modern payment workflows and automate money movement.",
      "keywords": "HIFI, payments API, programmable money, payment orchestration, payment workflows, automated flows, composable payments, workflow builder, payment automation, orchestration layer, flow composition, fintech API, stablecoins, USDC, USDT, bank transfers, ACH, SWIFT, RTP, KYC, KYB, compliance, virtual accounts, payouts, webhooks, developer documentation",
      "author": "HIFI",
      "robots": "index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1",
      "og:title": "HIFI Docs",
      "og:type": "website",
      "og:url": "https://docs.hifi.com/",
      "og:description": "Build modern payment workflows and automate money movement.",
      "og:site_name": "HIFI Docs",
      "og:locale": "en_US",
      "twitter:card": "summary",
      "twitter:site": "@hifibridge",
      "twitter:title": "HIFI Docs",
      "twitter:description": "Build modern payment workflows and automate money movement.",
      "theme-color": "#33171E",
      "application-name": "HIFI Docs",
      "apple-mobile-web-app-title": "HIFI Docs"
    },
    "links": [
      {
        "rel": "sitemap",
        "href": "https://docs.hifi.com/sitemap.xml"
      },
      {
        "rel": "alternate",
        "href": "https://docs.hifi.com/",
        "hreflang": "x-default"
      },
      {
        "rel": "alternate",
        "href": "https://docs.hifi.com/",
        "hreflang": "en"
      },
      {
        "rel": "manifest",
        "href": "/site.webmanifest"
      },
      {
        "rel": "icon",
        "href": "/favicon.svg",
        "type": "image/svg+xml"
      },
      {
        "rel": "icon",
        "href": "/favicon-32x32.png",
        "sizes": "32x32",
        "type": "image/png"
      },
      {
        "rel": "icon",
        "href": "/favicon-192.png",
        "sizes": "192x192",
        "type": "image/png"
      },
      {
        "rel": "apple-touch-icon",
        "href": "/apple-touch-icon.png",
        "sizes": "180x180"
      },
      {
        "rel": "preconnect",
        "href": "https://app.hifi.com",
        "crossorigin": ""
      }
    ],
    "jsonld": [
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "HIFI",
        "url": "https://hifi.com",
        "logo": "https://docs.hifi.com/og.png",
        "sameAs": [
          "https://x.com/hifibridge",
          "https://github.com/Hifi-Bridge",
          "https://www.linkedin.com/company/hifibridge"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "HIFI Docs",
        "url": "https://docs.hifi.com/",
        "description": "Build modern payment workflows and automate money movement.",
        "publisher": {
          "@type": "Organization",
          "name": "HIFI",
          "url": "https://hifi.com"
        },
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://docs.hifi.com/search?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    ],
    "verifications": {
      "google": "GOOGLE_SITE_VERIFICATION_TOKEN",
      "bing": "BING_SITE_VERIFICATION_TOKEN"
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.hifi.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/hifibridge",
      "github": "https://github.com/Hifi-Bridge",
      "linkedin": "https://www.linkedin.com/company/hifibridge"
    }
  },
  "navigation": {
    "versions": [
      {
        "version": "v2",
        "default": true,
        "tag": "Latest"
      }
    ]
  },
  "redirects": [
    {
      "source": "/quickstart",
      "destination": "/guides/quickstart"
    },
    {
      "source": "/docs/:slug*",
      "destination": "/:slug*"
    }
  ]
}
